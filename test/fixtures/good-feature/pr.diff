new file mode 100644
index 0000000..b31f2c8
--- /dev/null
+++ b/src/report/csv.js
@@ -0,0 +1,58 @@
+// CSV formatter for usage reports. Column order is part of the public
+// contract (see docs/usage.md); append new columns at the end only.
+const COLUMNS = ['account_id', 'period', 'requests', 'bytes_in', 'bytes_out', 'plan'];
+
+function escapeField(value) {
+  const s = String(value ?? '');
+  if (/[",\r\n]/.test(s)) {
+    return `"${s.replace(/"/g, '""')}"`;
+  }
+  return s;
+}
+
+export function csvHeader() {
+  return COLUMNS.join(',');
+}
+
+export function csvRow(entry) {
+  return COLUMNS.map((c) => escapeField(entry[c])).join(',');
+}
+
+export async function* csvLines(reportIterator) {
+  yield csvHeader();
+  for await (const entry of reportIterator) {
+    yield csvRow(entry);
+  }
+}
+
+export async function writeCsv(reportIterator, stream) {
+  for await (const line of csvLines(reportIterator)) {
+    if (!stream.write(`${line}\n`)) {
+      await new Promise((resolve) => stream.once('drain', resolve));
+    }
+  }
+}
+
+export function csvFilename(period) {
+  return `usage-${period.year}-${String(period.month).padStart(2, '0')}.csv`;
+}
+
+// Small helper kept here (rather than utils) because the quoting rules are
+// CSV-specific and should not be reused for other formats accidentally.
+export function previewRows(entries, limit = 5) {
+  const rows = [csvHeader()];
+  for (const entry of entries.slice(0, limit)) {
+    rows.push(csvRow(entry));
+  }
+  return rows;
+}
+
+export default {
+  csvHeader,
+  csvRow,
+  csvLines,
+  writeCsv,
+  csvFilename,
+  previewRows,
+};

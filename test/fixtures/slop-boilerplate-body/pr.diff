diff --git a/src/api/retry.js b/src/api/retry.js
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/src/api/retry.js
@@ -0,0 +1,80 @@
+export async function withRetry(operation, options = {}) {
+  const maxAttempts = options.maxAttempts ?? 3;
+  const baseDelay = options.baseDelay ?? 250;
+  let lastError;
+  for (let attempt = 1; attempt <= maxAttempts; attempt += 1) {
+    try {
+      return await operation();
+    } catch (error) {
+      lastError = error;
+      const delay = baseDelay * 2 ** (attempt - 1);
+      await new Promise((resolve) => setTimeout(resolve, delay));
+    }
+  }
+  throw lastError;
+}
+
+export async function withRetryPolicy0(operation) {
+  return withRetry(operation, { maxAttempts: 2 });
+}
+
+export async function withRetryPolicy1(operation) {
+  return withRetry(operation, { maxAttempts: 3 });
+}
+
+export async function withRetryPolicy2(operation) {
+  return withRetry(operation, { maxAttempts: 4 });
+}
+
+export async function withRetryPolicy3(operation) {
+  return withRetry(operation, { maxAttempts: 5 });
+}
+
+export async function withRetryPolicy4(operation) {
+  return withRetry(operation, { maxAttempts: 2 });
+}
+
+export async function withRetryPolicy5(operation) {
+  return withRetry(operation, { maxAttempts: 3 });
+}
+
+export async function withRetryPolicy6(operation) {
+  return withRetry(operation, { maxAttempts: 4 });
+}
+
+export async function withRetryPolicy7(operation) {
+  return withRetry(operation, { maxAttempts: 5 });
+}
+
+export async function withRetryPolicy8(operation) {
+  return withRetry(operation, { maxAttempts: 2 });
+}
+
+export async function withRetryPolicy9(operation) {
+  return withRetry(operation, { maxAttempts: 3 });
+}
+
+export async function withRetryPolicy10(operation) {
+  return withRetry(operation, { maxAttempts: 4 });
+}
+
+export async function withRetryPolicy11(operation) {
+  return withRetry(operation, { maxAttempts: 5 });
+}
+
+export async function withRetryPolicy12(operation) {
+  return withRetry(operation, { maxAttempts: 2 });
+}

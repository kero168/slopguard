diff --git a/test/csv-export.test.js b/test/csv-export.test.js
new file mode 100644
index 0000000..4efc7aa
--- /dev/null
+++ b/test/csv-export.test.js
@@ -0,0 +1,54 @@
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { csvHeader, csvRow, csvLines, previewRows } from '../src/report/csv.js';
+
+test('header lists the documented columns in order', () => {
+  assert.equal(
+    csvHeader(),
+    'account_id,period,requests,bytes_in,bytes_out,plan',
+  );
+});
+
+test('quotes fields containing commas', () => {
+  const row = csvRow({ account_id: 'a,b', period: '2024-06', requests: 3 });
+  assert.ok(row.startsWith('"a,b",2024-06,3'));
+});
+
+test('doubles embedded quotes per RFC 4180', () => {
+  const row = csvRow({ account_id: 'say "hi"', period: '2024-06' });
+  assert.ok(row.startsWith('"say ""hi""",'));
+});
+
+test('empty report still yields a header', async () => {
+  async function* empty() {}
+  const lines = [];
+  for await (const line of csvLines(empty())) lines.push(line);
+  assert.deepEqual(lines, [csvHeader()]);
+});
+
+test('multi-page iterators are streamed in order', async () => {
+  async function* pages() {
+    yield { account_id: 'a1', period: '2024-06', requests: 1 };
+    yield { account_id: 'a2', period: '2024-06', requests: 2 };
+  }
+  const lines = [];
+  for await (const line of csvLines(pages())) lines.push(line);
+  assert.equal(lines.length, 3);
+  assert.ok(lines[1].startsWith('a1,'));
+  assert.ok(lines[2].startsWith('a2,'));
+});
+
+test('previewRows caps output', () => {
+  const entries = Array.from({ length: 10 }, (_, i) => ({
+    account_id: `a${i}`,
+    period: '2024-06',
+  }));
+  assert.equal(previewRows(entries, 3).length, 4);
+});
diff --git a/docs/usage.md b/docs/usage.md
index 2ab01f9..77e3c02 100644
--- a/docs/usage.md
+++ b/docs/usage.md
@@ -41,6 +41,22 @@ reports generate --period 2024-06 --account acme
 
 The default output is JSON, one object per line.
 
+### CSV export
+
+```
+reports generate --period 2024-06 --account acme --csv --output usage.csv
+```
+
+Columns, in order:
+
+| column | meaning |
+| --- | --- |
+| `account_id` | account identifier |
+| `period` | `YYYY-MM` |
+| `requests` | total API requests |
+| `bytes_in` / `bytes_out` | transfer totals |
+| `plan` | plan name at the end of the period |
+
 ## Retention
 
 Reports older than 18 months are archived.
